---
import Principal from '@layout/Principal.astro';
import { cargarDatos } from '@helpers/idiomas';

const idioma = 'es';
const legal = await cargarDatos<any>(idioma, 'legal');
const seo = await cargarDatos<any>(idioma, 'seo');
const datos = legal.privacidad;
---

<Principal
  idioma={idioma}
  seo={{
    titulo: seo.paginas.privacidad.titulo,
    descripcion: seo.paginas.privacidad.descripcion,
  }}
>
  <article class="bg-[var(--color-carbon)] pt-32 lg:pt-40 pb-[var(--spacing-seccion)]">
    <div class="contenedor max-w-3xl">
      <p class="font-mono text-xs text-[var(--color-acero-claro)] uppercase tracking-widest mb-4">Última actualización: {datos.ultimaActualizacion}</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold leading-tight mb-6">{datos.titulo}</h1>
      <p class="text-base lg:text-lg text-white/85 leading-relaxed mb-12">{datos.introduccion}</p>
      <div class="flex flex-col gap-10">
        {datos.secciones.map((s: { titulo: string; contenido: string }) => (
          <section>
            <h2 class="text-xl lg:text-2xl font-semibold mb-3">{s.titulo}</h2>
            <p class="text-base text-white/80 leading-relaxed">{s.contenido}</p>
          </section>
        ))}
      </div>
    </div>
  </article>
</Principal>
