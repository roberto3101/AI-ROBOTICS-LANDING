---
import Principal from '@layout/Principal.astro';
import { cargarDatos } from '@helpers/idiomas';

const idioma = 'en';
const inicio = await cargarDatos<any>(idioma, 'inicio');
const prensa = await cargarDatos<any>(idioma, 'prensa');
const seo = await cargarDatos<{ paginas: { inicio: { titulo: string; descripcion: string } } }>(idioma, 'seo');

const diapositivas = inicio.hero.diapositivas ?? [];
const carruselProductos = [
  { titulo: 'AI Surveillance System', video: '/theme/uploads/ai-robotics/camara-seguridad.mp4' },
  { titulo: 'Defense Drone', video: '/theme/uploads/ai-robotics/dron-closeup.mp4' },
  { titulo: 'Autonomous Turret', video: '/theme/uploads/ai-robotics/cyber-tech.mp4' },
  { titulo: 'Command Center', video: '/theme/uploads/ai-robotics/centro-datos.mp4' },
];
---

<Principal
  idioma={idioma}
  seo={{
    titulo: seo.paginas.inicio.titulo,
    descripcion: seo.paginas.inicio.descripcion,
    imagen: '/theme/uploads/ai-robotics/hero-aerial.jpg',
    tipo: 'website',
  }}
  claseBody="home wp-singular page-template"
>
  <section class="overflow-hidden relative z-[3] js-rotate-arrow-container js-hero-slider" data-type="hero">
    <ul class="w-screen h-screen js-rotate-arrow-slider" data-type="hero" data-modifier="none">
      {diapositivas.map((d: any) => (
        <li class="h-screen !flex flex-wrap justify-center items-center lg:items-end pb-0 lg:pb-20 relative">
          <video src={d.video ?? '/theme/uploads/ai-robotics/hero-aerial.mp4'} poster={d.imagen ?? ''} class="w-full h-screen object-cover absolute top-0 left-0" autoplay muted playsinline loop></video>
          <div class="container w-full mx-auto text-center relative z-[1] js-rotate-arrow-slider-content px-6 lg:px-0">
            <span class="sub-title text-primary block mb-4 opacity-80">{d.etiqueta}</span>
            <h1 class="w-full text-[32px] lg:text-[100px] leading-tight">{d.titulo}</h1>
            <p class="w-full mt-3 text-base lg:text-2xl opacity-80 max-w-xl mx-auto">{d.descripcion}</p>
            <div class="pt-6 lg:pt-10 2xl:pt-20 lg:pb-10"></div>
            <div class="flex justify-center gap-3 lg:gap-6 mt-2 lg:mt-8 mx-auto">
              <a href={d.ctaRuta} class="button js-info-button">{d.ctaEtiqueta}</a>
            </div>
          </div>
          <div class="hidden lg:block w-[45%] h-screen absolute top-0 left-0 z-[1] js-slider-trigger js-slider-prev"></div>
          <div class="hidden lg:block w-[45%] h-screen absolute top-0 right-0 z-[1] js-slider-trigger js-slider-next"></div>
        </li>
      ))}
    </ul>
  </section>

  <div class="pt-12 lg:pt-24 pb-0 bg-[#050506] relative z-[3]"></div>

  <div class="info-text py-16 lg:py-32 bg-[#050506] px-4 lg:px-0 relative z-[3]">
    <div class="lg:w-3/4 max-w-[1010px] mx-auto text-center js-scroll-activate">
      <blockquote class="!my-0 !px-9 lg:!px-12 lg:text-balance text-cloud">
        <p class="text-2xl lg:text-3xl leading-none lg:leading-[1.2]">{inicio.manifiesto.parrafo}</p>
        <div class="button__top"></div>
        <div class="button__bottom"></div>
      </blockquote>
    </div>
  </div>

  <div class="bg-[#050506] pt-12 lg:pt-40 pb-24 lg:pb-32 overflow-hidden relative z-[3] js-scroll-activate">
    <div class="container flex flex-wrap justify-between items-start">
      <div class="lg:w-1/2">
        <h3 class="section-title text-balance">{inicio.productosDestacados.titulo}</h3>
      </div>
      <a href={`/${idioma}/products`} class="button mt-8 lg:mt-0">View products</a>
    </div>

    <div class="mt-14 lg:mt-20 relative js-rotate-arrow-container">
      <ul class="w-full js-rotate-arrow-slider" data-type="centered">
        {carruselProductos.map((p) => (
          <li>
            <video src={p.video} class="aspect-[.841/1] object-cover" autoplay muted playsinline loop></video>
            <h4 class="lg:text-3.5xl text-white mt-4 lg:mt-8">{p.titulo}</h4>
          </li>
        ))}
      </ul>
      <div class="hidden lg:block w-[45%] h-screen absolute top-0 left-0 z-[1] js-slider-trigger js-slider-prev"></div>
      <div class="hidden lg:block w-[45%] h-screen absolute top-0 right-0 z-[1] js-slider-trigger js-slider-next"></div>
    </div>
  </div>

  <div class="py-20 lg:py-40 bg-[#050506] relative z-[1]">
    <div class="container js-scroll-activate">
      <div class="lg:flex justify-between gap-28 items-center flex-row-reverse">
        <img src="/theme/uploads/ai-robotics/centro-datos.jpg" alt="" class="w-full lg:w-[53%] aspect-square object-cover" />
        <div class="w-full lg:w-[47%] pt-10 lg:pt-0 h-full flex flex-wrap">
          <h3 class="section-title section-title--mobile">{inicio.comoFunciona.titulo}</h3>
          <p class="mt-5 lg:mt-10 text-balance">
            Without reliable autonomy, surveillance is only reaction. Our platform processes video at the edge, detects real threats and triggers the right response — drone, turret, alert — without waiting for the operator to be watching the screen.
          </p>
          <a href="/en/about" class="button mt-5 lg:mt-10">Learn More</a>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-[var(--ai-noche)] py-20 lg:py-32 relative z-[1]" id="projects-in-progress">
    <div class="container js-scroll-activate">
      <div class="flex flex-wrap justify-between items-end gap-6">
        <div>
          <p class="sub-title text-teal">[{prensa.proyectosEnCurso.etiqueta}]</p>
          <h3 class="section-title mt-4 max-w-[900px]">{prensa.proyectosEnCurso.titulo}</h3>
        </div>
        <a href="/en/press" class="button">View newsroom</a>
      </div>
      <ul class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-8">
        {prensa.proyectosEnCurso.items.map((p: any) => (
          <li class="border border-[var(--ai-borde)] overflow-hidden bg-[var(--ai-noche-suave)]">
            <div class="aspect-[16/10] relative overflow-hidden">
              {p.video ? (
                <video src={p.video} autoplay muted playsinline loop preload="metadata" poster={p.imagen} class="absolute inset-0 w-full h-full object-cover"></video>
              ) : (
                <img src={p.imagen} alt={p.titulo} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              )}
              <span class="absolute top-4 left-4 sub-title text-teal bg-[var(--ai-noche)]/85 px-3 py-1 border border-teal">[{p.etapa.toUpperCase()}]</span>
            </div>
            <div class="p-6 lg:p-8">
              <h4 class="text-white text-xl lg:text-2xl tracking-tight leading-tight">{p.titulo}</h4>
              <p class="sub-title opacity-70 mt-3">{p.estadoActual}</p>
              <p class="mt-4 text-[15px] opacity-85">{p.descripcion}</p>
              <ul class="mt-6 flex flex-col gap-2">
                {p.siguientesPasos.map((paso: string) => (
                  <li class="flex items-start gap-3 text-[14px]">
                    <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full" style="background-color:var(--ai-teal)" aria-hidden="true"></span>
                    <span class="opacity-85">{paso}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="bg-cloud py-12 lg:pt-80 lg:pb-32 text-black relative z-[3]">
    <div class="container flex flex-wrap justify-between items-start js-scroll-activate">
      <div class="lg:w-1/2">
        <p class="sub-title sub-title--black">[ENTERPRISE CONTACT]</p>
        <h3 class="section-title mt-6 lg:mt-10 text-balance">{inicio.ctaCierre.titulo}</h3>
      </div>
      <a href={inicio.ctaCierre.ctaPrimario.ruta} class="button button--white mt-12 lg:mt-0">
        {inicio.ctaCierre.ctaPrimario.etiqueta.toUpperCase()}
      </a>
    </div>
  </div>

  <div class="-mt--160 lg:-mt--320"></div>

  <section class="bg-cloud relative z-[3] text-black pt-10 overflow-hidden">
    <div class="container lg:mt-24 js-scroll-activate">
      <h3 class="section-title tracking-tighter max-w-[1100px] text-center lg:text-left">{inicio.casosDeUso.titulo}</h3>
    </div>
    <div class="mt-14 lg:mt-24 border-t border-t-[#505051] border-opacity-100 border-b border-b-[#505051] js-scroll-activate">
      <ul class="flex flex-wrap lg:container">
        {inicio.casosDeUso.items.map((caso: any, idx: number) => (
          <li class={`peek-block relative w-full lg:w-1/3 ${idx !== 0 ? 'border-t border-t-[#505051] lg:border-t-0' : ''} ${idx < inicio.casosDeUso.items.length - 1 ? 'lg:border-r border-r-[#505051]' : ''} overflow-hidden`}>
            <a href={caso.ruta ?? '/en/products'}>
              <img src={`/theme/uploads/ai-robotics/caso-${(idx % 3) + 1}.jpg`} alt="" class="lg:absolute w-full lg:h-full object-cover top-0 left-0 pt-4 px-4 lg:p-0" />
              <div class="peek-block__container flex flex-wrap content-between justify-start relative z-[1] bg-cloud xl:px-20 pt-10 pb-14 lg:py-28 lg:min-h-[31rem] px-8 xl:px-16">
                <div class="w-full text-center lg:text-left">
                  <h4 class="lg:min-h-[80px] flex items-center">{caso.titulo}</h4>
                  <p class="mt-8 lg:mt-3">{caso.descripcion}</p>
                </div>
                <span class="arrow-link arrow-link--black block mt-10 lg:mt-0 mx-auto lg:mx-0">Read more</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Principal>
