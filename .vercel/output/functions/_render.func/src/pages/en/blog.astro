---
import Principal from '@layout/Principal.astro';
import HeroNosotros from '@componentes/nosotros/HeroNosotros.astro';
import EncabezadoSeccion from '@componentes/ui/EncabezadoSeccion.astro';
import { obtenerPosts } from '@helpers/cms';

const idioma = 'en';
const posts = await obtenerPosts(idioma, { limite: 12 });
const formatoFecha = new Intl.DateTimeFormat('en-US', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Principal
  idioma={idioma}
  seo={{
    titulo: 'Blog \u2014 AI Robotics',
    descripcion: 'Technical articles, case studies and learnings from the AI Robotics team.',
  }}
>
  <HeroNosotros
    etiqueta="[BLOG]"
    titulo="Ideas, learnings and technical notes."
    subtitulo="We share what we learn building autonomous systems: technical decisions, failures, use cases and how we work."
    imagen="/imagenes/hero/empresa-2.jpg"
  />

  <section class="bg-[var(--color-carbon-claro)] py-[var(--spacing-seccion)] border-y border-white/5">
    <div class="contenedor">
      <EncabezadoSeccion etiqueta="[LATEST POSTS]" titulo="What we\u2019re writing about." />

      {posts.length === 0 ? (
        <div class="mt-12 tarjeta p-10 lg:p-14 text-center max-w-2xl mx-auto">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--ai-teal)] mb-4">[COMING SOON]</p>
          <h3 class="text-2xl lg:text-3xl font-semibold mb-3">We\u2019re preparing the first batch of articles.</h3>
          <p class="text-base text-white/75">
            Once we publish, this space will fill up automatically. Leave us your email and we\u2019ll let you know.
          </p>
          <a href="/en/contact?subject=general" class="boton boton-primario mt-8 inline-flex">Notify me</a>
        </div>
      ) : (
        <ul class="mt-12 grid gap-6 md:grid-cols-2">
          {posts.map((p) => (
            <li class="tarjeta p-6 lg:p-8 flex flex-col gap-3">
              <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-acero-claro)]">
                <span class="text-[var(--ai-teal)]">{p.categoria}</span>
                <span>·</span>
                <time datetime={p.fecha}>{formatoFecha.format(new Date(p.fecha))}</time>
                <span>·</span>
                <span>{p.lectura}</span>
              </div>
              <a href={`/en/blog/${p.slug}`} class="block">
                <h3 class="text-xl lg:text-2xl font-semibold leading-tight text-white hover:text-[var(--ai-teal)] transition-colors">{p.titulo}</h3>
              </a>
              <p class="text-sm text-white/75 leading-relaxed">{p.resumen}</p>
              <a href={`/en/blog/${p.slug}`} class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--ai-teal)] mt-auto inline-flex items-center gap-2">
                Read article →
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Principal>
