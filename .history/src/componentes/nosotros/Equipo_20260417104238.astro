---
interface Miembro {
  nombre: string;
  cargo: string;
  bio: string;
  foto: string;
  categoria: string;
}

interface Props {
  etiquetaSeccion?: string;
  tituloSeccion?: string;
  subtitulo?: string;
  miembros: Miembro[];
  notaPlaceholder?: string;
}

const { etiquetaSeccion, tituloSeccion, subtitulo, miembros = [], notaPlaceholder } = Astro.props;
---

<section class="bg-cloud relative z-[3] text-black py-20 lg:py-32">
  <div class="container js-scroll-activate">
    
    {tituloSeccion && (
      <>
        {etiquetaSeccion && <p class="sub-title sub-title--black">[{etiquetaSeccion}]</p>}
        <h3 class="section-title mt-6 lg:mt-10 max-w-[900px]">{tituloSeccion}</h3>
        {subtitulo && <p class="mt-5 max-w-[700px]">{subtitulo}</p>}
      </>
    )}

    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mt-14">
      {miembros.map((m) => (
        <li class="bg-carbon text-white flex flex-col h-full">
          
          <div class="aspect-[4/5] overflow-hidden bg-black/10">
            <img 
              src={m.foto} 
              alt={m.nombre} 
              class="w-full h-full object-cover" 
              loading="lazy" 
            />
          </div>

          <div class="p-6 lg:p-8 flex flex-col gap-2 flex-1">
            <p class="sub-title">[{m.cargo}]</p>
            
            <h4 class="text-white mt-3">
              {m.nombre}
            </h4>

            {/* 🔥 AQUÍ está el fix real */}
            <p class="text-[15px] text-white/80 leading-relaxed mt-3">
              {m.bio}
            </p>

          </div>
        </li>
      ))}
    </ul>

    {notaPlaceholder && (
      <p class="mt-8 text-sm opacity-60 italic">{notaPlaceholder}</p>
    )}

  </div>
</section>