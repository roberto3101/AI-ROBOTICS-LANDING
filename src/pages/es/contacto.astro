---
import Principal from '@layout/Principal.astro';
import HeroNosotros from '@componentes/nosotros/HeroNosotros.astro';
import InfoContacto from '@componentes/contacto/InfoContacto.astro';
import Formulario from '@componentes/contacto/Formulario.astro';
import { cargarDatos, cargarTextosUi } from '@helpers/idiomas';

export const prerender = false;

const idioma = 'es';
const datos = await cargarDatos<any>(idioma, 'contacto');
const seo = await cargarDatos<any>(idioma, 'seo');
const textosUi = await cargarTextosUi<any>(idioma);

const asunto = Astro.url.searchParams.get('asunto') ?? '';
---

<Principal
  idioma={idioma}
  seo={{
    titulo: seo.paginas.contacto.titulo,
    descripcion: seo.paginas.contacto.descripcion,
  }}
>
  <HeroNosotros
    etiqueta={datos.hero.etiqueta}
    titulo={datos.hero.titulo}
    subtitulo={datos.hero.subtitulo}
    imagen="/imagenes/hero/empresa-3.jpg"
  />

  <section class="bg-[#050506] py-20 lg:py-32">
    <div class="container grid lg:grid-cols-[1fr_1.2fr] gap-12 lg:gap-20 items-start">
      <div>
        <p class="sub-title">[DATOS DE CONTACTO]</p>
        <h2 class="section-title section-title--mobile mt-6 mb-8">Conversemos.</h2>
        <InfoContacto items={datos.datosContacto} />
      </div>
      <Formulario
        formulario={datos.formulario}
        tiposConsulta={datos.tiposConsulta}
        textosUi={textosUi}
        asuntoInicial={asunto}
      />
    </div>
  </section>
</Principal>
