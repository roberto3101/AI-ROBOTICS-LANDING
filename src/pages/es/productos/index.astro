---
import Principal from '@layout/Principal.astro';
import EncabezadoSeccion from '@componentes/ui/EncabezadoSeccion.astro';
import TarjetaProducto from '@componentes/ui/TarjetaProducto.astro';
import CtaCierre from '@componentes/inicio/CtaCierre.astro';
import { cargarDatos } from '@helpers/idiomas';

const idioma = 'es';
const datos = await cargarDatos<any>(idioma, 'productos');
const seo = await cargarDatos<any>(idioma, 'seo');
const inicio = await cargarDatos<any>(idioma, 'inicio');
---

<Principal
  idioma={idioma}
  seo={{
    titulo: seo.paginas.productos.titulo,
    descripcion: seo.paginas.productos.descripcion,
  }}
>
  <section class="bg-[var(--color-carbon)] pt-36 pb-16 lg:pt-44 lg:pb-24">
    <div class="contenedor">
      <EncabezadoSeccion etiqueta={datos.indice.etiqueta} titulo={datos.indice.titulo} descripcion={datos.indice.subtitulo} />
    </div>
  </section>

  <section class="bg-[var(--color-carbon)] pb-[var(--spacing-seccion)]">
    <div class="contenedor grid lg:grid-cols-3 gap-6">
      {datos.lista.map((p: any) => (
        <TarjetaProducto
          etiqueta={p.etiquetaCorta}
          titulo={p.titulo}
          descripcion={p.descripcionCorta}
          imagen={p.imagenHero}
          imagenAlt={p.titulo}
          ctaEtiqueta="Ver detalles"
          ctaRuta={`/es/productos/${p.slugEs}`}
        />
      ))}
    </div>
  </section>

  <CtaCierre
    etiqueta={inicio.ctaCierre.etiqueta}
    titulo={inicio.ctaCierre.titulo}
    descripcion={inicio.ctaCierre.descripcion}
    ctaPrimario={inicio.ctaCierre.ctaPrimario}
    ctaSecundario={inicio.ctaCierre.ctaSecundario}
    imagen={inicio.ctaCierre.imagen}
  />
</Principal>
