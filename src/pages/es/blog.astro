---
import Principal from '@layout/Principal.astro';
import HeroNosotros from '@componentes/nosotros/HeroNosotros.astro';
import EncabezadoSeccion from '@componentes/ui/EncabezadoSeccion.astro';
import { obtenerPosts } from '@helpers/cms';

const idioma = 'es';
const posts = await obtenerPosts(idioma, { limite: 12 });
const formatoFecha = new Intl.DateTimeFormat('es-PE', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Principal
  idioma={idioma}
  seo={{
    titulo: 'Blog — AI Robotics',
    descripcion: 'Artículos técnicos, casos de uso y aprendizajes del equipo de AI Robotics.',
  }}
>
  <HeroNosotros
    etiqueta="[BLOG]"
    titulo="Ideas, aprendizajes y notas técnicas."
    subtitulo="Publicamos lo que aprendemos construyendo sistemas autónomos: decisiones técnicas, fallos, casos de uso y cómo trabajamos."
    imagen="/imagenes/hero/empresa-2.jpg"
  />

  <section class="bg-[var(--color-carbon-claro)] py-[var(--spacing-seccion)] border-y border-white/5">
    <div class="contenedor">
      <EncabezadoSeccion etiqueta="[ÚLTIMAS ENTRADAS]" titulo="Qué estamos escribiendo." />

      {posts.length === 0 ? (
        <div class="mt-12 tarjeta p-10 lg:p-14 text-center max-w-2xl mx-auto">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--ai-teal)] mb-4">[PRÓXIMAMENTE]</p>
          <h3 class="text-2xl lg:text-3xl font-semibold mb-3">Estamos preparando el primer lote de artículos.</h3>
          <p class="text-base text-white/75">
            Cuando publiquemos, este espacio se llenará automáticamente. Si quieres que te avisemos, déjanos tu correo.
          </p>
          <a href="/es/contacto?asunto=general" class="boton boton-primario mt-8 inline-flex">Avísame cuando publiquen</a>
        </div>
      ) : (
        <ul class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((p) => (
            <li class="tarjeta-blog flex flex-col">
              <a href={`/es/blog/${p.slug}`} class="block group">
                <div class="aspect-[16/10] overflow-hidden bg-[var(--color-carbon)] border-b border-white/10">
                  {p.portada ? (
                    <img src={p.portada} alt={p.titulo} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                  ) : (
                    <div class="w-full h-full relative overflow-hidden bg-gradient-to-br from-[#0a1f24] via-[#0c0c10] to-[#1a0a28]">
                      <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 30%, rgba(0,211,205,0.5) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(120,80,200,0.35) 0%, transparent 50%);"></div>
                      <div class="absolute inset-0 grid place-items-center px-6">
                        <p class="font-mono text-2xl font-bold tracking-wide text-white/25 uppercase text-center">{p.categoria}</p>
                      </div>
                    </div>
                  )}
                </div>
              </a>
              <div class="p-6 flex-1 flex flex-col gap-3">
                <div class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-acero-claro)] flex-wrap">
                  <span class="text-[#00D3CD]">[{p.categoria}]</span>
                  <span>·</span>
                  <time datetime={p.fecha}>{formatoFecha.format(new Date(p.fecha))}</time>
                  <span>·</span>
                  <span>{p.lectura}</span>
                </div>
                <a href={`/es/blog/${p.slug}`} class="block">
                  <h3 class="text-xl font-semibold leading-tight text-white hover:text-[#00D3CD] transition-colors">{p.titulo}</h3>
                </a>
                <p class="text-sm text-white/70 leading-relaxed line-clamp-3">{p.resumen}</p>
                <a href={`/es/blog/${p.slug}`} class="font-mono text-xs uppercase tracking-[0.18em] text-[#00D3CD] mt-auto inline-flex items-center gap-2 hover:gap-3 transition-all">
                  Leer artículo →
                </a>
              </div>
            </li>
          ))}
        </ul>

        <style>
          .tarjeta-blog {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            overflow: hidden;
            transition: border-color 240ms ease, transform 240ms ease;
          }
          .tarjeta-blog:hover {
            border-color: rgba(0, 211, 205, 0.4);
            transform: translateY(-2px);
          }
          .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
          }
        </style>
      )}
    </div>
  </section>
</Principal>
