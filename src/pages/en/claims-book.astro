---
import Principal from '@layout/Principal.astro';
import { cargarDatos } from '@helpers/idiomas';

const idioma = 'en';
const legal = await cargarDatos<any>(idioma, 'legal');
const seo = await cargarDatos<any>(idioma, 'seo');
const datos = legal.libroReclamaciones;
---

<Principal
  idioma={idioma}
  seo={{
    titulo: seo.paginas.libroReclamaciones.titulo,
    descripcion: seo.paginas.libroReclamaciones.descripcion,
  }}
>
  <article class="bg-[var(--color-carbon)] pt-32 lg:pt-40 pb-[var(--spacing-seccion)]">
    <div class="contenedor max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold leading-tight mb-6">{datos.titulo}</h1>
      <p class="text-base lg:text-lg text-white/85 leading-relaxed mb-8">{datos.introduccion}</p>

      <div class="tarjeta p-8 mb-8">
        <p class="text-base text-white/80 mb-6">{datos.instrucciones}</p>
        <a
          href={datos.enlaceLibro.url}
          class="boton boton-primario"
          target="_blank"
          rel="noopener noreferrer"
        >
          {datos.enlaceLibro.etiqueta}
        </a>
      </div>

      <section class="border-t border-white/10 pt-8">
        <h2 class="text-2xl font-semibold mb-5">Company details</h2>
        <dl class="grid sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">
          <div>
            <dt class="etiqueta-mono mb-1">Legal name</dt>
            <dd class="text-white">{datos.datosEmpresa.razonSocial}</dd>
          </div>
          <div>
            <dt class="etiqueta-mono mb-1">RUC</dt>
            <dd class="text-white">{datos.datosEmpresa.ruc}</dd>
          </div>
          <div>
            <dt class="etiqueta-mono mb-1">Address</dt>
            <dd class="text-white">{datos.datosEmpresa.direccion}</dd>
          </div>
          <div>
            <dt class="etiqueta-mono mb-1">Phone</dt>
            <dd class="text-white">{datos.datosEmpresa.telefono}</dd>
          </div>
          <div>
            <dt class="etiqueta-mono mb-1">Email</dt>
            <dd class="text-white">{datos.datosEmpresa.correo}</dd>
          </div>
        </dl>
        <p class="mt-8 text-sm text-[var(--color-acero-claro)] italic">{datos.notaLegal}</p>
      </section>
    </div>
  </article>
</Principal>
