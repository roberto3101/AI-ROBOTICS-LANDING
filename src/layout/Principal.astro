---
import '@estilos/global.css';

import BarraNavegacion from '@componentes/navegacion/BarraNavegacion.astro';
import PieDePagina from '@componentes/navegacion/PieDePagina.astro';
import EtiquetasPagina from '@componentes/seo/EtiquetasPagina.astro';
import { ClientRouter } from 'astro:transitions';

import { cargarDatos, cargarTextosUi, LOCALES_HTML, type Idioma } from '@helpers/idiomas';
import { calcularSeo, organizacionJsonLd, type DatosSeo } from '@helpers/seo';

interface Props {
  idioma: Idioma;
  seo: DatosSeo;
  pathActual?: string;
  jsonLdAdicional?: Record<string, unknown> | Record<string, unknown>[];
  claseBody?: string;
}

const { idioma, seo, pathActual, jsonLdAdicional, claseBody = '' } = Astro.props;
const path = pathActual ?? Astro.url.pathname;

const [navegacion, footerData, empresa, seoData, textosUi] = await Promise.all([
  cargarDatos<any>(idioma, 'navegacion'),
  cargarDatos<any>(idioma, 'footer'),
  cargarDatos<any>(idioma, 'empresa'),
  cargarDatos<{ global: any }>(idioma, 'seo'),
  cargarTextosUi<any>(idioma),
]);

const seoComputado = calcularSeo(idioma, path, seo, seoData.global);

const jsonLdLista: Record<string, unknown>[] = [organizacionJsonLd(empresa)];
if (jsonLdAdicional) {
  if (Array.isArray(jsonLdAdicional)) jsonLdLista.push(...jsonLdAdicional);
  else jsonLdLista.push(jsonLdAdicional);
}
if (seo.jsonLd) {
  if (Array.isArray(seo.jsonLd)) jsonLdLista.push(...seo.jsonLd);
  else jsonLdLista.push(seo.jsonLd);
}
seoComputado.jsonLd = jsonLdLista;

const rutaInicio = `/${idioma}/`;
---

<!DOCTYPE html>
<html lang={LOCALES_HTML[idioma]} class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#050506" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.png" />
    <link rel="preconnect" href="https://challenges.cloudflare.com" />

    <link rel="stylesheet" href="/theme/theme.css" />
    <link rel="stylesheet" href="/theme/airobotics-override.css?v=3" />

    <!-- Inline safety net: evita que el contenido quede invisible si el JS
         del tema externo falla al revelar .js-scroll-activate, .aparecer o
         inicializar el slider Slick del hero (lo que dejaba la home en negro). -->
    <style is:inline>
      .js-scroll-activate { opacity: 1 !important; }
      .aparecer { opacity: 1 !important; transform: none !important; }
      /* Slick slides sin inicializar: mostrar siempre el primero (resto lo esconde Slick tras init) */
      .slick-slide { display: block !important; }
      .js-rotate-arrow-slider:not(.slick-initialized) > li:not(:first-child) { display: none !important; }
    </style>

    <EtiquetasPagina seo={seoComputado} siteName={seoData.global.siteName} twitter={seoData.global.twitter} />

    <slot name="head" />

    <ClientRouter />

    <script is:inline>
      // Persistencia de tema — corre ANTES del render para evitar flash.
      // Default: oscuro (no se añade ninguna clase). Solo "light" activa la clase.
      (function () {
        try {
          var saved = localStorage.getItem('tema');
          if (saved === 'light') {
            document.documentElement.classList.add('light');
          } else {
            document.documentElement.classList.remove('light');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={`home ${claseBody}`}>
    <BarraNavegacion
      navegacion={navegacion}
      idioma={idioma}
      pathActual={path}
      rutaInicio={rutaInicio}
      textosUi={textosUi}
    />

    <main>
      <slot />
    </main>

    <PieDePagina footer={footerData} idioma={idioma} />

    <div class="cursor u-flex u-flex--center" id="js-cursor" transition:persist>
      <div class="cursor__circle flex justify-center items-center">
        <span class="cursor__text block text-center"></span>
      </div>
    </div>

    <div class="arrow-cursor" transition:persist>
      <div class="cursor__circle flex items-center justify-center">
        <svg class="arrow-cursor__icon" width="26" height="32" viewBox="0 0 26 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g style="mix-blend-mode:screen">
            <path class="arrow-cursor__path" d="M11.5 7.99969L19.5 15.9997L11.5 23.9997" stroke="#000"/>
          </g>
        </svg>
      </div>
    </div>

    <script is:inline>
      /* Shim: app.js del tema shield.ai referencia `Lenis`. Le damos un no-op
         para que no reviente y dejamos el scroll nativo. */
      window.Lenis = window.Lenis || function(){
        return {
          on(){}, off(){}, raf(){}, scrollTo(){}, start(){}, stop(){},
          destroy(){}, notify(){}, resize(){}, emit(){}, get targetScroll(){return 0;}, get scroll(){return 0;}
        };
      };
    </script>
    <script src="/theme/app.js" is:inline></script>

    <!-- Cursor: tomamos el control total del posicionamiento de #js-cursor.
         NO tocamos su tamaño ni visibilidad (eso lo sigue controlando el
         theme: base 0x0 / .learn 220x220). SÍ aplicamos el transform cada
         frame con translate(-50%,-50%) para que el CENTRO del retículo
         quede exactamente bajo el puntero. Esto también soluciona el
         "stuck en la esquina superior izquierda" porque siempre parkeamos
         el cursor fuera de pantalla hasta el primer pointermove. -->
    <script is:inline>
      (function ownCursor() {
        if (matchMedia('(pointer: coarse)').matches) return;

        var cursor = document.getElementById('js-cursor');
        if (!cursor) return;

        var mx = -9999, my = -9999, gotMove = false;

        function writeTransform(el) {
          if (!el) return;
          el.style.setProperty(
            'transform',
            'translate3d(' + mx + 'px,' + my + 'px,0) translate(-50%,-50%)',
            'important'
          );
        }

        function paint() {
          writeTransform(cursor);
          requestAnimationFrame(paint);
        }

        function onMove(e) {
          mx = e.clientX; my = e.clientY;
          if (!gotMove) gotMove = true;
          // Escritura inmediata (además del RAF) para evitar cualquier
          // frame con posición desactualizada.
          writeTransform(cursor);
        }
        function onLeave() {
          // Al salir de la ventana, parkeamos fuera de pantalla para que
          // no aparezca "stuck" en una esquina.
          mx = -9999; my = -9999;
          gotMove = false;
          writeTransform(cursor);
        }

        document.addEventListener('pointermove', onMove, { passive: true, capture: true });
        document.addEventListener('pointerdown',  onMove, { passive: true, capture: true });
        document.addEventListener('mouseleave',   onLeave);
        window.addEventListener('blur',           onLeave);

        // ClientRouter de Astro reemplaza el DOM en cada navegación.
        // Interceptamos ambos eventos: ANTES del swap parkeamos el nuevo
        // cursor inline (si ya existe en el HTML que llega), y DESPUÉS
        // reasignamos la referencia y forzamos la escritura inmediata.
        function resetCursorState() {
          // Tras navegar con ClientRouter, los elementos que dispararon
          // mouseenter fueron reemplazados → el theme nunca recibe el
          // mouseleave correspondiente y el cursor queda "atascado" en
          // estados como .learn (220x220), .video, .link, etc.
          // Limpiamos manualmente y dejamos que el próximo mouseenter real
          // re-establezca el estado correcto.
          var c = document.getElementById('js-cursor');
          if (c) {
            c.classList.remove('learn', 'link', 'video', 'drag', 'play', 'close', 'view', 'is-active', 'active', 'is-hover');
          }
          var arrow = document.querySelector('.arrow-cursor');
          if (arrow) {
            arrow.classList.remove('learn', 'active', 'is-active', 'is-hover');
          }
          document.body.classList.remove('cursor-learn', 'cursor-link');
        }

        function rebindCursor() {
          var nuevo = document.getElementById('js-cursor');
          if (nuevo) cursor = nuevo;
          resetCursorState();
          // Park si nunca hubo movimiento real en esta sesión
          if (!gotMove) { mx = -9999; my = -9999; }
          // Escribir AL MISMO TIEMPO que tomamos la referencia nueva,
          // ANTES de que el navegador pinte el primer frame con el
          // elemento nuevo sin transform → elimina el flash top-left.
          writeTransform(cursor);
        }
        // Reset también ANTES de la preparación, para que el snapshot
        // "old" de la view-transition no congele el cursor en 220x220.
        document.addEventListener('astro:before-preparation', resetCursorState);
        document.addEventListener('astro:before-swap', rebindCursor);
        document.addEventListener('astro:after-swap',  rebindCursor);
        document.addEventListener('astro:page-load',   rebindCursor);
        // Cubrimos también el caso del restore desde bfcache
        window.addEventListener('pageshow', rebindCursor);

        paint();
      })();
    </script>

    <script is:inline>
      // Re-aplica el tema tras cada navegación del ClientRouter, porque
      // Astro reemplaza las clases del <html> con las que vienen del HTML
      // de la nueva página (donde no hay .light aunque el usuario lo tenga).
      (function persistThemeAcrossNavigation() {
        function apply() {
          try {
            var saved = localStorage.getItem('tema');
            if (saved === 'light') {
              document.documentElement.classList.add('light');
            } else {
              document.documentElement.classList.remove('light');
            }
          } catch (e) {}
        }
        // antes del paint del nuevo DOM → sin flash
        document.addEventListener('astro:before-swap', function (e) {
          try {
            var saved = localStorage.getItem('tema');
            if (e.newDocument && e.newDocument.documentElement) {
              if (saved === 'light') e.newDocument.documentElement.classList.add('light');
              else e.newDocument.documentElement.classList.remove('light');
            }
          } catch (err) {}
        });
        document.addEventListener('astro:after-swap', apply);
        document.addEventListener('astro:page-load', apply);
        window.addEventListener('pageshow', apply);
      })();
    </script>

    <script is:inline>
      // Cierra submenús del header ANTES de que Astro tome el snapshot
      // "old" para la view-transition. Si no, el dropdown abierto queda
      // congelado en el snapshot y se ve como "render stale" bajo la
      // máscara del polygon-gradient.
      (function closeHeaderDropdownsBeforeNav() {
        function closeAll() {
          // Submenús del theme: visibles cuando NO tienen .hidden
          document.querySelectorAll('.header__nav--alt').forEach(function (el) {
            el.classList.add('hidden');
          });
          // Disparador con estado "activo" (si el theme lo marca)
          document.querySelectorAll('.js-toggle-nav.is-active, .js-toggle-nav.active').forEach(function (el) {
            el.classList.remove('is-active');
            el.classList.remove('active');
          });
          // Menú hamburguesa mobile por si estaba abierto
          document.body.classList.remove('nav-open', 'menu-open');
          document.documentElement.classList.remove('nav-open', 'menu-open');
        }
        document.addEventListener('astro:before-preparation', closeAll);
      })();
    </script>

    <script is:inline>
      (function initThemeToggle() {
        function bind() {
          document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
            if (btn.dataset.bound) return;
            btn.dataset.bound = '1';
            function syncIcons() {
              var light = document.documentElement.classList.contains('light');
              var sun  = btn.querySelector('.theme-toggle__icon--sun');
              var moon = btn.querySelector('.theme-toggle__icon--moon');
              if (sun)  sun.style.display  = light ? 'none'  : 'inline';
              if (moon) moon.style.display = light ? 'inline' : 'none';
            }
            syncIcons();
            btn.addEventListener('click', function () {
              var toggle = function () {
                document.documentElement.classList.toggle('light');
                try { localStorage.setItem('tema', document.documentElement.classList.contains('light') ? 'light' : 'dark'); } catch (e) {}
                syncIcons();
              };
              if (!document.startViewTransition) { toggle(); return; }
              document.startViewTransition(toggle);
            });
          });
        }
        bind();
        document.addEventListener('astro:page-load', bind);
      })();
    </script>
  </body>
</html>
