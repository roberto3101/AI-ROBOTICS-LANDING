---
interface Hito { anio: string; titulo: string; descripcion: string; }
interface Props {
  etiqueta: string;
  titulo: string;
  hitos: Hito[];
}

const { etiqueta, titulo, hitos } = Astro.props;
---

<div class="bg-[#050506] py-20 lg:py-40 relative z-[1]">
  <div class="container js-scroll-activate">
    <p class="sub-title">[{etiqueta}]</p>
    <h3 class="section-title section-title--mobile mt-6 lg:mt-10 max-w-[900px]">{titulo}</h3>
    <ul class="mt-14 lg:mt-20 border-t border-t-[#363636]">
      {hitos.map((h) => (
        <li class="grid grid-cols-1 lg:grid-cols-[120px_1fr] gap-6 lg:gap-12 py-8 lg:py-12 border-b border-b-[#363636]">
          <p class="sub-title text-primary">{h.anio}</p>
          <div>
            <h4 class="text-white">{h.titulo}</h4>
            <p class="mt-3 text-[15px] opacity-80">{h.descripcion}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</div>
