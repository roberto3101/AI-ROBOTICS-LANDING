---
interface Props {
  etiqueta: string;
  titulo: string;
  tagline: string;
  descripcion: string;
  estado: string;
  publicoObjetivo: string[];
  video?: string;
  imagen: string;
  textosUi: { comun: { contactanos: string; solicitarDemo: string } };
  rutaContacto: string;
  rutaDemo: string;
}

const {
  etiqueta,
  titulo,
  tagline,
  descripcion,
  estado,
  publicoObjetivo,
  video,
  imagen,
  textosUi,
  rutaContacto,
  rutaDemo,
} = Astro.props;
---

<section class="h-screen !flex flex-wrap justify-between items-end pb-16 lg:pb-20 relative bg-carbon overflow-hidden">
  {video ? (
    <video src={video} autoplay muted playsinline loop preload="metadata" poster={imagen} class="w-full h-screen object-cover absolute top-0 left-0 opacity-70" aria-hidden="true"></video>
  ) : (
    <img src={imagen} alt="" class="w-full h-screen object-cover absolute top-0 left-0 opacity-60" loading="eager" />
  )}
  <div class="container w-full mx-auto text-center relative z-[1]">
    <p class="sub-title">[{etiqueta}]</p>
    <h1 class="w-full text-[48px] lg:text-[100px] mt-4">{titulo}</h1>
    <p class="w-full mt-3 text-xl lg:text-2xl">{tagline}</p>
    <p class="w-full mt-5 text-base lg:text-lg opacity-80 max-w-[800px] mx-auto">{descripcion}</p>
    <div class="flex justify-center flex-wrap gap-3 lg:gap-6 mt-6 lg:mt-8 mx-auto">
      <a href={rutaDemo} class="button button--red">{textosUi.comun.solicitarDemo.toUpperCase()}</a>
    </div>
    <div class="flex justify-center flex-wrap gap-3 mt-8">
      <span class="sub-title text-primary">[{estado.toUpperCase()}]</span>
      {publicoObjetivo.map((p) => (
        <span class="sub-title opacity-70">· {p}</span>
      ))}
    </div>
  </div>
</section>
