---
interface ItemPaso { numero: string; titulo: string; descripcion: string; }
interface ItemGrid { icono: string; titulo: string; descripcion: string; }

interface Seccion {
  titulo: string;
  tipo: 'pasos' | 'grid' | 'lista' | 'texto';
  items?: (ItemPaso | ItemGrid | string)[];
  contenido?: string;
}

interface Props {
  seccion: Seccion;
  variante?: 'oscuro' | 'claro';
}

const { seccion, variante = 'oscuro' } = Astro.props;
const esOscuro = variante === 'oscuro';
const fondo = esOscuro ? 'bg-[#050506] text-white' : 'bg-cloud text-black relative z-[3]';
---

<section class={`${fondo} py-20 lg:py-32`}>
  <div class="container js-scroll-activate">
    <h3 class="section-title section-title--mobile">{seccion.titulo}</h3>

    {seccion.tipo === 'pasos' && seccion.items && (
      <ul class="mt-14 lg:mt-20 border-t border-t-[#363636]">
        {(seccion.items as ItemPaso[]).map((p) => (
          <li class="grid grid-cols-1 lg:grid-cols-[120px_1fr] gap-6 lg:gap-12 py-8 lg:py-12 border-b border-b-[#363636]">
            <p class={`sub-title ${esOscuro ? 'text-primary' : ''}`}>{p.numero}</p>
            <div>
              <h4 class={esOscuro ? 'text-white' : ''}>{p.titulo}</h4>
              <p class={`mt-3 text-[15px] ${esOscuro ? 'opacity-80' : ''}`}>{p.descripcion}</p>
            </div>
          </li>
        ))}
      </ul>
    )}

    {seccion.tipo === 'grid' && seccion.items && (
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 mt-14">
        {(seccion.items as ItemGrid[]).map((it) => (
          <li class={`${esOscuro ? 'bg-carbon' : 'bg-carbon text-white'} p-8 lg:p-10 min-h-[260px] flex flex-col justify-between`}>
            <img src={it.icono} alt="" class="w-12 h-12 object-contain" loading="lazy" />
            <div class="mt-8">
              <h4 class="text-white">{it.titulo}</h4>
              <p class="mt-3 text-[15px] opacity-80">{it.descripcion}</p>
            </div>
          </li>
        ))}
      </ul>
    )}

    {seccion.tipo === 'lista' && seccion.items && (
      <ul class="mt-12 grid md:grid-cols-2 gap-x-12 gap-y-4 max-w-4xl">
        {(seccion.items as string[]).map((it) => (
          <li class={`flex items-start gap-3 text-base ${esOscuro ? 'text-white/90' : 'text-[var(--ai-navy-profundo)]'}`}>
            <span class="flex-shrink-0 mt-2 w-1.5 h-1.5 rounded-full" style={`background-color:${esOscuro ? 'var(--ai-teal)' : 'var(--ai-teal-sombra)'}`} aria-hidden="true"></span>
            <span>{it}</span>
          </li>
        ))}
      </ul>
    )}

    {seccion.tipo === 'texto' && seccion.contenido && (
      <p class={`mt-8 text-base lg:text-lg leading-relaxed max-w-3xl ${esOscuro ? 'text-white/85' : 'text-[var(--ai-navy-profundo)]'}`}>{seccion.contenido}</p>
    )}
  </div>
</section>
