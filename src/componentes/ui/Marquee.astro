---
interface Props {
  video?: string;
  texto?: string;
  items?: string[];
  ariaLabel?: string;
}

const { video, texto, items, ariaLabel = 'banda decorativa' } = Astro.props;
---

<div class="relative overflow-hidden border-y border-white/5 bg-[var(--ai-noche-suave)] py-6" aria-label={ariaLabel}>
  {items && items.length > 0 && (
    <div class="marquee-track">
      {[...items, ...items, ...items].map((it) => (
        <span class="font-mono text-xs uppercase tracking-[0.25em] text-white/80 inline-flex items-center gap-3 whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--ai-teal)]" aria-hidden="true"></span>
          {it}
        </span>
      ))}
    </div>
  )}
  {texto && !items && (
    <p class="font-mono text-sm uppercase tracking-[0.3em] text-white/80 text-center">{texto}</p>
  )}
</div>
