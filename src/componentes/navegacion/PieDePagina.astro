---
import type { Idioma } from '@helpers/idiomas';

interface ColumnaPie { titulo: string; enlaces: { etiqueta: string; ruta: string }[] }
interface Red { nombre: string; url: string }

interface FooterData {
  logoMarca: { src: string; alt: string; ancho: number; alto: number };
  logoPrimario?: { src: string; alt: string };
  lemaFinal: string;
  respaldo: string;
  ctaFinal: { titulo: string; descripcion: string; etiquetaBoton: string; ruta: string };
  columnas: ColumnaPie[];
  redes: Red[];
  copyright: string;
  credito: string;
}

interface Props {
  footer: FooterData;
  idioma: Idioma;
}

const { footer, idioma } = Astro.props;
const anio = new Date().getFullYear();
const copyright = footer.copyright.replace('{anio}', String(anio));
const logoPrimarioSrc = footer.logoPrimario?.src ?? '/imagenes/logos/airobotics-oscuro.svg';
---

<footer class="footer relative pt-20 lg:pt-48 bg-cloud text-[#292E3A] z-[3]">
  <div class="container block lg:flex justify-between">
    <div class="lhs flex lg:block flex-wrap lg:justify-center lg:w-96">
      <a href={`/${idioma}/`}>
        <img src={logoPrimarioSrc} alt={footer.logoMarca.alt} />
      </a>
      <p class="mt-10">{footer.lemaFinal}</p>
      <div class="flex flex-wrap gap-6 mt-8 justify-start">
        <a href={`/${idioma}/contacto`} class="button button--white">
          {idioma === 'es' ? 'Contáctanos' : 'Contact Us'}
        </a>
      </div>
      <small class="sub-title text-xs !mt-10 mb-0 absolute lg:static">{copyright}</small>
    </div>

    <div class="middle flex flex-wrap lg:flex-nowrap gap-y-10 lg:gap-y-0 lg:w-96 xl:w-1/3 justify-between items-start sub-title text-xs mb-0 opacity-100 mt-10 lg:mt-0">
      <div class="flex flex-wrap gap-y-10 lg:gap-y-14 w-full lg:w-auto">
        {footer.columnas.slice(0, Math.ceil(footer.columnas.length / 2)).map((columna) => (
          <ul class="flex flex-wrap gap-y-3 lg:gap-y-4 md:w-1/2 lg:w-auto">
            <li><p>{columna.titulo}</p></li>
            {columna.enlaces.map((e) => (
              <li><a href={e.ruta} class="opacity-50">{e.etiqueta}</a></li>
            ))}
          </ul>
        ))}
      </div>

      <div class="flex flex-wrap gap-y-10 lg:gap-y-14 w-full lg:w-auto">
        {footer.columnas.slice(Math.ceil(footer.columnas.length / 2)).map((columna) => (
          <ul class="flex flex-wrap gap-y-3 lg:gap-y-4 w-full md:w-1/2 lg:w-auto">
            <li><p>{columna.titulo}</p></li>
            {columna.enlaces.map((e) => (
              <li><a href={e.ruta} class="opacity-50">{e.etiqueta}</a></li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <div class="lg:w-40 flex flex-wrap sub-title text-xs mb-0 opacity-100 gap-y-6 mt-10 lg:mt-0 content-start">
      <p class="w-full">{idioma === 'es' ? 'Redes' : 'Social'}</p>
      <ul class="redes-sociales flex flex-wrap gap-3">
        {footer.redes.map((r) => {
          const n = (r.nombre || '').toLowerCase();
          const tipo = n.includes('linkedin') ? 'linkedin'
            : n.includes('youtube')  ? 'youtube'
            : n.includes('instagram')? 'instagram'
            : n.includes('facebook') ? 'facebook'
            : n.includes('tiktok')   ? 'tiktok'
            : 'x';
          return (
            <li>
              <a href={r.url} aria-label={r.nombre} rel="noopener noreferrer" target="_blank">
                <span class="icon" aria-hidden="true">
                  {tipo === 'linkedin' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.95v5.66H9.34V9h3.42v1.56h.05c.48-.91 1.65-1.86 3.4-1.86 3.64 0 4.31 2.4 4.31 5.52v6.23zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
                  )}
                  {tipo === 'youtube' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"/></svg>
                  )}
                  {tipo === 'instagram' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.22.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.05.41 2.22.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.22-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.05.36-2.22.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.22-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.05-.41-2.22C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.22.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.05-.36 2.22-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.8.3-1.47.71-2.13 1.38A5.9 5.9 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.3.8.71 1.47 1.38 2.13a5.9 5.9 0 0 0 2.13 1.38c.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.9 5.9 0 0 0 2.13-1.38 5.9 5.9 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.9 5.9 0 0 0-1.38-2.13A5.9 5.9 0 0 0 19.86.63C19.1.33 18.22.13 16.95.07 15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/></svg>
                  )}
                  {tipo === 'facebook' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M13.4 24v-9.8h3.3l.5-3.8h-3.8V8c0-1.1.3-1.9 1.9-1.9h2V2.7c-.3 0-1.5-.1-2.9-.1-2.9 0-4.8 1.7-4.8 4.9v2.8H6.3v3.8h3.3V24h3.8z"/></svg>
                  )}
                  {tipo === 'tiktok' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M19.6 6.8a5.9 5.9 0 0 1-3.3-1.6 5.9 5.9 0 0 1-1.8-3.2h-3.2v13.4a2.9 2.9 0 1 1-2.9-2.9c.3 0 .6 0 .9.1V9.3a6.1 6.1 0 1 0 5.3 6v-6.9a9.1 9.1 0 0 0 5 1.5V6.8z"/></svg>
                  )}
                  {tipo === 'x' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
                  )}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
  <div class="footer-mega-wrap pt-16 lg:pt-24 pb-8 select-none" aria-label={footer.logoMarca.alt} data-glowy>
    <div class="footer-mega-wordmark" aria-hidden="true">AIROBOTICS</div>
    <div class="footer-mega-wordmark footer-mega-wordmark--overlay" aria-hidden="true">AIROBOTICS</div>
  </div>
  <script is:inline>
    (function initGlowy() {
      function bind() {
        document.querySelectorAll('[data-glowy]').forEach(function (el) {
          if (el.dataset.glowyBound) return;
          el.dataset.glowyBound = '1';
          el.addEventListener('pointermove', function (e) {
            var rect = el.getBoundingClientRect();
            el.style.setProperty('--x', (e.clientX - rect.left) + 'px');
            el.style.setProperty('--y', (e.clientY - rect.top) + 'px');
            el.style.setProperty('--r', '320px');
          });
          el.addEventListener('pointerenter', function () {
            el.style.setProperty('--r', '320px');
          });
          el.addEventListener('pointerleave', function () {
            el.style.setProperty('--r', '0px');
          });
        });
      }
      bind();
      document.addEventListener('astro:page-load', bind);
    })();
  </script>
</footer>
