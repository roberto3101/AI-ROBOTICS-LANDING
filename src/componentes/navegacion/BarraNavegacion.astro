---
import type { Idioma } from '@helpers/idiomas';
import { obtenerRutaEquivalente } from '@helpers/idiomas';

interface ItemSubmenu { etiqueta: string; ruta: string; descripcion?: string; icono?: string; }
interface ItemMenu {
  etiqueta: string;
  ruta: string;
  destacado?: boolean;
  submenu?: ItemSubmenu[];
}

interface NavegacionData {
  logo: { src: string; alt: string; ancho: number; alto: number };
  menu: ItemMenu[];
  ctaPrincipal: { etiqueta: string; ruta: string };
  selectorIdioma: { etiqueta: string; opciones: { codigo: Idioma; etiqueta: string; bandera: string; ruta: string }[] };
  anuncio?: { etiqueta: string; texto: string; ruta: string };
}

interface Props {
  navegacion: NavegacionData;
  idioma: Idioma;
  pathActual: string;
  rutaInicio: string;
  textosUi: { comun: { abrirMenu: string; cerrarMenu: string; cambiarIdioma: string } };
}

const { navegacion, idioma, pathActual, textosUi } = Astro.props;
const otroIdioma: Idioma = idioma === 'es' ? 'en' : 'es';
const rutaOtro = obtenerRutaEquivalente(pathActual, otroIdioma);
const banderaActual = `/banderas/${idioma}.svg`;
const banderaOtro = `/banderas/${otroIdioma}.svg`;
const textoCambio = idioma === 'es' ? 'Cambiar a inglés' : 'Switch to Spanish';
const anuncioEtiqueta = navegacion.anuncio?.etiqueta ?? (idioma === 'es' ? '[NOTICIAS]' : '[NEWS]');
const anuncioTexto = navegacion.anuncio?.texto ?? (idioma === 'es'
  ? 'Nuevo sistema autónomo de vigilancia con IA disponible para municipalidades.'
  : 'New AI-powered autonomous surveillance system available for municipalities.');
const anuncioRuta = navegacion.anuncio?.ruta ?? `/${idioma}/prensa`;
const ctaEsExterno = /^https?:\/\//i.test(navegacion.ctaPrincipal.ruta);
---

<header class="header fixed w-full z-20" id="js-header">
  <div class="container flex items-center justify-between pt-6 lg:pt-10 pb-6 lg:pb-6">
    <a href={`/${idioma}/`} class="logo-airobotics w-[180px] lg:w-[240px] block">
      <img src={navegacion.logo.src} alt={navegacion.logo.alt} class="logo-airobotics__img logo-airobotics__img--dark w-full h-auto" />
      <img src="/imagenes/logos/airobotics-oscuro.svg" alt={navegacion.logo.alt} class="logo-airobotics__img logo-airobotics__img--light w-full h-auto" />
    </a>
    <nav class="header__main">
      <ul class="relative gap-x-7 hidden lg:flex">
        {navegacion.menu.map((item) => (
          <li>
            {item.submenu && item.submenu.length > 0 ? (
              <>
                <a href="#" class="relative js-toggle-nav">
                  {item.etiqueta}
                  <div class="button__top"></div>
                  <div class="button__bottom"></div>
                </a>
                <div class="header__nav header__nav--alt container hidden js-nav-item">
                  <div class="js-nav-overlay"></div>
                  <div class="flex flex-wrap bg-carbon relative z-[1]">
                    <ul class="rhs">
                      {item.submenu.map((sub) => (
                        <li class={`group !w-1/${Math.max(2, Math.min(4, item.submenu!.length))}`}>
                          <a href={sub.ruta} class="group-hover:!bg-white">
                            {sub.descripcion && <span class="sub-title transition-colors relative z-[1]">[{sub.descripcion.slice(0, 40).toUpperCase()}]</span>}
                            <div class="w-full relative z-[1]">
                              <h4 class="transition-colors">{sub.etiqueta}</h4>
                              {sub.descripcion && <p class="mt-3 transition-colors">{sub.descripcion}</p>}
                            </div>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </>
            ) : (
              <a href={item.ruta} class="relative">
                {item.etiqueta}
                <div class="button__top"></div>
                <div class="button__bottom"></div>
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
    <div class="header__right flex items-center gap-3">
      <button type="button" class="theme-toggle" aria-label="Cambiar tema" data-theme-toggle>
        <svg class="theme-toggle__icon theme-toggle__icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg class="theme-toggle__icon theme-toggle__icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a
        href={rutaOtro}
        class="selector-idioma inline-flex items-center gap-2 px-3 py-2 rounded-full border border-white/15 text-[12px] font-mono uppercase tracking-wider transition"
        aria-label={textoCambio}
        hreflang={otroIdioma}
        title={textoCambio}
      >
        <img class="selector-idioma__desde h-3.5 w-5 rounded-sm object-cover" src={banderaActual} alt="" aria-hidden="true" />
        <span class="selector-idioma__label">{idioma.toUpperCase()}</span>
        <svg width="10" height="8" viewBox="0 0 12 10" fill="none" aria-hidden="true"><path d="M1 5h10M7 1l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <img src={banderaOtro} alt="" aria-hidden="true" class="h-3.5 w-5 rounded-sm object-cover" />
      </a>
      <a
        href={navegacion.ctaPrincipal.ruta}
        class="header__cta hidden lg:inline-flex lg:flex items-center gap-2 px-3 py-2 rounded-full border border-white/15 text-[12px] font-mono uppercase tracking-wider transition"
        target={ctaEsExterno ? '_blank' : undefined}
        rel={ctaEsExterno ? 'noopener noreferrer' : undefined}
      >
        {navegacion.ctaPrincipal.etiqueta}
      </a>
    </div>
    <div class="header__hamburger js-toggle-nav"></div>
  </div>
</header>

<div class="menu" id="js-menu">
  <div class="container flex flex-wrap content-between pb-5">
    <ul class="menu__nav">
      {navegacion.menu.map((item) => (
        <li class="py-7 border-b border-b-carbon border-opacity-100">
          {item.submenu && item.submenu.length > 0 ? (
            <>
              <a href="#" class="sub-title text-[15px] tracking-[.11em] opacity-100 js-toggle-sub">{item.etiqueta}</a>
              <ul class="menu__sub js-menu-sub">
                {item.submenu.map((sub) => (
                  <li><a href={sub.ruta}>{sub.etiqueta}</a></li>
                ))}
              </ul>
            </>
          ) : (
            <a href={item.ruta} class="sub-title text-[15px] tracking-[.11em] opacity-100">{item.etiqueta}</a>
          )}
        </li>
      ))}
      <li class="py-7 border-b border-b-carbon border-opacity-100">
        <a href={rutaOtro} class="sub-title text-[15px] tracking-[.11em] opacity-100 inline-flex items-center gap-3" hreflang={otroIdioma}>
          <img src={banderaOtro} alt="" width="22" height="16" class="h-4 w-[22px] object-cover" aria-hidden="true" />
          {otroIdioma === 'en' ? 'English' : 'Español'}
        </a>
      </li>
      <li class="py-7 border-b border-b-carbon border-opacity-100">
        <a
          href={navegacion.ctaPrincipal.ruta}
          class="sub-title text-[15px] tracking-[.11em] opacity-100"
          target={ctaEsExterno ? '_blank' : undefined}
          rel={ctaEsExterno ? 'noopener noreferrer' : undefined}
        >
          {navegacion.ctaPrincipal.etiqueta}
        </a>
      </li>
    </ul>
  </div>
</div>

<script is:inline>
  (function () {
    if (window.__airoNavBound) return;
    window.__airoNavBound = true;

    document.addEventListener('click', function (e) {
      var hamb = e.target.closest('.header__hamburger');
      if (hamb) {
        var menu = document.getElementById('js-menu');
        var header = document.getElementById('js-header');
        if (!menu || !header) return;
        e.preventDefault();
        e.stopImmediatePropagation();
        var willOpen = !menu.classList.contains('is-shown');
        menu.classList.toggle('is-shown', willOpen);
        header.classList.toggle('is-opened', willOpen);
        hamb.classList.toggle('is-opened', willOpen);
        return;
      }

      var trigger = e.target.closest('.js-toggle-sub');
      if (trigger && trigger.closest('#js-menu')) {
        e.preventDefault();
        e.stopImmediatePropagation();
        var parent = trigger.parentElement;
        var sub = parent && parent.querySelector('.js-menu-sub');
        if (!sub) return;
        var open = sub.classList.toggle('is-open');
        sub.style.display = open ? 'block' : 'none';
        trigger.classList.toggle('is-opened', open);
      }
    }, true);

    function resetMenu() {
      var menu = document.getElementById('js-menu');
      var header = document.getElementById('js-header');
      if (menu) menu.classList.remove('is-shown');
      if (header) header.classList.remove('is-opened');
      var hamb = document.querySelector('.header__hamburger');
      if (hamb) hamb.classList.remove('is-opened');
      document.querySelectorAll('.js-menu-sub').forEach(function (el) {
        el.classList.remove('is-open');
        el.style.display = '';
      });
      document.querySelectorAll('.js-toggle-sub.is-opened').forEach(function (el) {
        el.classList.remove('is-opened');
      });
    }
    document.addEventListener('astro:after-swap', resetMenu);
  })();
</script>
